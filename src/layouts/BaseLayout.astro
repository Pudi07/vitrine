---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Site web pour activites locales | Plus de clients, moins de friction",
  description = "Un site clair, rapide et moderne pour transformer vos visiteurs en appels, reservations et demandes de devis."
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8fafc" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="border-b border-[var(--color-border)] bg-white/80 backdrop-blur">
      <div class="section-shell flex items-center justify-between py-4">
        <a href="/" class="text-sm font-semibold tracking-wide text-slate-900">Pierre Barth</a>
        <a href="#contact" class="btn-primary text-xs sm:text-sm">Demander un devis</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-[var(--color-border)] bg-white">
      <div class="section-shell py-8 text-center text-sm text-[var(--color-muted)]">
        <p>Pierre Barth - Je cree des sites vitrines pour restaurants, gites et artisans de ma region.</p>
      </div>
    </footer>
  </body>
</html>
