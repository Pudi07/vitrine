---
interface Props {
  label?: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { label, title, description, centered = false } = Astro.props;
---

<div class:list={["max-w-3xl", centered && "mx-auto text-center"]}>
  {label && (
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-accent)]">
      {label}
    </p>
  )}
  <h2 class="text-balance text-3xl font-semibold leading-tight text-slate-950 sm:text-4xl">
    {title}
  </h2>
  {description && (
    <p class="mt-4 text-pretty text-base leading-relaxed text-[var(--color-muted)] sm:text-lg">
      {description}
    </p>
  )}
</div>
