---
import { Image } from "astro:assets";
import websiteMockup from "../assets/images/Website Mockup.png";
---

<section class="relative isolate overflow-hidden pt-0 pb-16 sm:pb-24">
  <div class="hero-backdrop absolute inset-0 z-0" aria-hidden="true"></div>
  <div
    class="absolute inset-0 z-10"
    style="background: var(--hero-overlay-gradient);"
  ></div>

  <div class="section-shell relative z-20 grid gap-8 pt-16 sm:pt-24 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div
      class="rounded-3xl p-6 text-center backdrop-blur-sm sm:p-8 lg:-ml-8 lg:text-left"
      style="border: 1px solid var(--hero-card-border); background: var(--hero-card-bg); box-shadow: var(--hero-card-shadow);"
    >
      <h1 class="text-balance text-4xl font-semibold leading-tight text-[var(--color-text)] sm:text-5xl lg:text-6xl">
        Un site web qui vous apporte des clients, pas juste des visiteurs.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-pretty text-base leading-relaxed text-[var(--color-muted)] sm:text-lg lg:mx-0">
        Je crée des sites rapides et efficaces pour tous types d'entreprises et activités.
      </p>

      <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center lg:justify-start">
        <a href="#contact" class="btn-primary w-full sm:w-auto">Demander un devis</a>
        <a href="#exemples" class="btn-secondary w-full sm:w-auto">Voir un exemple</a>
      </div>
    </div>

    <figure class="relative lg:-mr-8">
      <div class="relative lg:translate-x-6 xl:translate-x-10">
        <Image
          src={websiteMockup}
          alt="Aperçu d'un site web sur ordinateur et mobile"
          width={1280}
          sizes="(min-width: 1280px) 42rem, (min-width: 1024px) 50vw, 92vw"
          quality="mid"
          priority
          fetchpriority="high"
          class="w-full max-w-none object-contain lg:scale-[1.18]"
        />
      </div>
    </figure>
  </div>
</section>
