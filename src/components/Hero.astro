<section class="relative isolate overflow-hidden pt-0 pb-16 sm:pb-24">
  <img
    src="/images/tim-oun-ZCnX6CR1Sto-unsplash.jpg"
    alt=""
    class="pointer-events-none absolute inset-0 z-0 h-full w-full object-cover object-top"
    loading="eager"
    decoding="async"
  />
  <div
    class="absolute inset-0 z-10"
    style="background: var(--hero-overlay-gradient);"
  ></div>

  <div class="section-shell relative z-20 grid gap-8 pt-16 sm:pt-24 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div
      class="rounded-3xl p-6 text-center backdrop-blur-sm sm:p-8 lg:-ml-8 lg:text-left"
      style="border: 1px solid var(--hero-card-border); background: var(--hero-card-bg); box-shadow: var(--hero-card-shadow);"
    >
      <h1 class="text-balance text-4xl font-semibold leading-tight text-[var(--color-text)] sm:text-5xl lg:text-6xl">
        Un site web qui vous apporte des clients, pas juste des visiteurs.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-pretty text-base leading-relaxed text-[var(--color-muted)] sm:text-lg lg:mx-0">
