---
import SectionHeading from "./SectionHeading.astro";

const projects = [
  {
    title: "Découvrir Salavas",
    image: "/images/Salavas_Site.png",
    description: "Site immersif pour valoriser un village touristique, avec navigation simple et mise en avant des points d’intérêt locaux.",
    href: "https://salavas.pierre-barth.workers.dev",
    external: true
  },
  {
    title: "Aven d'Orgnac Pédagogie",
    image: "/images/Aven_Orgnac_Site.png",
    description: "Interface web claire pour présenter des contenus pédagogiques, avec une navigation structurée et accessible pour différents publics.",
    href: "https://pedagogie.orgnac.com/",
    external: true
  },
  {
    title: "Espace Museo de l'OSUG (CNRS)",
    image: "/images/Osug_Site.png",
    description: "Conception d’interfaces et développement d’un globe interactif en temps réel, pour une installation publique fiable et fluide.",
    href: "/projets/espace-museo-osug",
    external: false
  }
];
---

<section id="exemples" class="py-16 sm:py-20">
  <div class="section-shell">
    <SectionHeading
      label="Exemples"
      title="Quelques réalisations"
    />

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        projects.map((project) => (
          <a
            href={project.href}
            target={project.external ? "_blank" : undefined}
            rel={project.external ? "noreferrer noopener" : undefined}
            class="group surface-card block overflow-hidden rounded-3xl transition-transform duration-300 hover:-translate-y-1"
          >
            <div class="aspect-[16/10] overflow-hidden border-b border-[var(--color-border)] bg-[var(--color-elevated)]">
              <img
                src={project.image}
                alt={`Aperçu du projet ${project.title}`}
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-6 sm:p-8">
              <h3 class="text-2xl font-semibold text-[var(--color-text)]">{project.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)] sm:text-base">{project.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>