---
import SectionHeading from "./SectionHeading.astro";

const services = [
  {
    title: "Creation de site vitrine",
    description: "Un site neuf, adapte a votre activite, pense pour rassurer et convertir."
  },
  {
    title: "Refonte de site existant",
    description: "Je modernise votre site actuel pour gagner en clarte et en impact."
  },
  {
    title: "Optimisation des performances",
    description: "Chargement rapide et experience fluide pour eviter de perdre des visiteurs."
  },
  {
    title: "SEO local essentiel",
    description: "Structure et contenus optimises pour mieux ressortir sur les recherches de proximite."
  }
];
---

<section id="services" class="py-16 sm:py-20">
  <div class="section-shell">
    <SectionHeading
      label="Services"
      title="Des offres simples pour des besoins concrets."
      description="Pas de jargon, pas de complexite inutile. Chaque service a un objectif clair: vous aider a generer plus de demandes."
    />

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {
        services.map((service) => (
          <article class="surface-card rounded-3xl p-6 sm:p-8">
            <h3 class="text-xl font-semibold text-slate-950">{service.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)] sm:text-base">{service.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
