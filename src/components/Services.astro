---
import SectionHeading from "./SectionHeading.astro";

const services = [
  {
    title: "Création de site vitrine",
    description: "Un site neuf, adapté à votre activité, pensé pour rassurer et convertir."
  },
  {
    title: "Refonte de site existant",
    description: "Je modernise votre site actuel pour gagner en clarté et en impact."
  },
  {
    title: "Optimisation des performances",
    description: "Chargement rapide et expérience fluide pour éviter de perdre des visiteurs."
  },
  {
    title: "SEO essentiel",
    description: "Structure et contenus optimisés pour mieux ressortir sur les recherches de proximité."
  }
];
---

<section id="services" class="py-16 sm:py-20">
  <div class="section-shell">
    <SectionHeading
      label="Services"
      title="Des offres simples pour des besoins concrets."
    />

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {
        services.map((service) => (
          <article class="surface-card rounded-3xl p-6 sm:p-8">
            <h3 class="text-xl font-semibold text-[var(--color-text)]">{service.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)] sm:text-base">{service.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
