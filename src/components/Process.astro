---
import SectionHeading from "./SectionHeading.astro";

const steps = [
  {
    number: "01",
    title: "Echange",
    description: "Je clarifie vos objectifs, vos priorites et les informations utiles pour vos clients."
  },
  {
    number: "02",
    title: "Creation",
    description: "Je concois un site clair et moderne, valide avec vous a chaque etape importante."
  },
  {
    number: "03",
    title: "Mise en ligne",
    description: "Votre site est publie, optimise et pret a recevoir des demandes des le premier jour."
  }
];
---

<section id="process" class="py-16 sm:py-20">
  <div class="section-shell">
    <SectionHeading
      label="Process"
      title="3 etapes simples, sans perte de temps."
      description="Un cadre clair pour avancer vite, avec un seul interlocuteur et des decisions faciles."
    />

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        steps.map((step) => (
          <article class="surface-card rounded-3xl p-6 sm:p-8">
            <p class="text-sm font-semibold text-[var(--color-accent)]">{step.number}</p>
            <h3 class="mt-3 text-2xl font-semibold text-slate-950">{step.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)] sm:text-base">{step.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
