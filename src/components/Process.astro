---
import SectionHeading from "./SectionHeading.astro";

const steps = [
  {
    number: "01",
    title: "Échange",
    description: "Je clarifie vos objectifs, vos priorités et les informations utiles pour vos clients."
  },
  {
    number: "02",
    title: "Création",
    description: "Je conçois un site clair et moderne, validé avec vous à chaque étape importante."
  },
  {
    number: "03",
    title: "Mise en ligne",
    description: "Votre site est publié, optimisé et prêt à recevoir des demandes dès le premier jour."
  }
];
---

<section id="process" class="py-16 sm:py-20">
  <div class="section-shell">
    <SectionHeading
      label="Déroulement"
      title="3 étapes simples, sans perte de temps."
    />

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        steps.map((step) => (
          <article class="surface-card rounded-3xl p-6 sm:p-8">
            <p class="text-sm font-semibold text-[var(--color-accent)]">{step.number}</p>
            <h3 class="mt-3 text-2xl font-semibold text-[var(--color-text)]">{step.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)] sm:text-base">{step.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
